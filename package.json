{
  "name": "clicknich",
  "version": "1.0.0",
  "description": "Platform para criar aplicativos personalizados para infoprodutos",
  "private": true,
  "workspaces": [
    "packages/frontend"
  ],
  "scripts": {
    "dev": "npm run dev -w packages/frontend",
